# SupplyMind .env.example — copy to .env and fill in
# .env is gitignored. NEVER commit real keys.

# Federal Reserve Economic Data (FRED) — commodity prices, FX, macro
# Free: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# NewsAPI — geopolitical event polling (Hormuz, Iran, Israel, Red Sea)
# Free 100 req/day: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Weights & Biases — experiment tracking (optional)
# Free: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here

# Hugging Face — model downloads + Space deploy
# Free: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# NOAA — weather / tropical cyclone feed
# Free: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=your_noaa_token_here

# Demo mode: forces deterministic scenarios (no live API calls)
DEMO_MODE=false

# Offline mode: disables all external network calls
OFFLINE_MODE=false

# OpenAI-compatible API for baseline agent (fallback, used only by inference.py)
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=gpt-4o
# OPENAI_API_KEY=fallback_for_HF_TOKEN

# GDELT, USGS, MarineTraffic are keyless or free tier — no env var needed.
